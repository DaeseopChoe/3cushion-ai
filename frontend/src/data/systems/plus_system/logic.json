{
  "system": "plus_system",

  "track_selection": {
    "strategy": "ruleset",
    "snap_tolerance": 0.02,

    "ruleset": [
      {
        "if": "CO.rail == BOTTOM && C1.known && C1.side == RIGHT",
        "then": "B2T_L"
      },
      {
        "if": "CO.rail == BOTTOM && C1.known && C1.side == LEFT",
        "then": "B2T_R"
      },
      {
        "if": "CO.rail == TOP && C1.known && C1.side == RIGHT",
        "then": "T2B_R"
      },
      {
        "if": "CO.rail == TOP && C1.known && C1.side == LEFT",
        "then": "T2B_L"
      },

      {
        "if": "CO.rail == BOTTOM && !C1.known && CO.x > C3.x",
        "then": "B2T_L"
      },
      {
        "if": "CO.rail == BOTTOM && !C1.known && CO.x < C3.x",
        "then": "B2T_R"
      },
      {
        "if": "CO.rail == TOP && !C1.known && CO.x > C3.x",
        "then": "T2B_R"
      },
      {
        "if": "CO.rail == TOP && !C1.known && CO.x < C3.x",
        "then": "T2B_L"
      }
    ],

    "tie_breaker": {
      "condition": "|CO.x - C3.x| <= 0.02",
      "priority": [
        "prefer_C3_side_rail",
        "prefer_existing_anchor"
      ]
    }
  },

  "required_marks": ["CO"],

  "optional_marks": ["C1", "C3"],

  "hp_policy": {
    "co_required": true,
    "pattern": "long-short-long",
    "description": "CO_sys + C1_sys = C3_sys"
  },

  "space_assumptions": {
    "rails": {
      "TOP": 42.25,
      "BOTTOM": -2.25,
      "LEFT": -2.25,
      "RIGHT": 82.25
    }
  },

  "notes": [
    "Plus system uses CO as mandatory reference mark",
    "If C1 is known, track is decided immediately by side rail",
    "If C1 is unknown, CO.x vs C3.x comparison is used",
    "Tie cases are resolved by C3 side rail, then anchor existence",
    "All sys calculations are performed outside logic.json"
  ],

  "meta": {
    "version": "1.0",
    "role": "system_logic"
  }
}
