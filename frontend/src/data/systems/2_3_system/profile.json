{
    "system": "2_3_system",
    "formula": {
        "expr": "C1_f = (CO_f - (1.5 * C3_f - HP_n * 3.3)) / 2"
    },
    "value_domains": {
        "CO_f": [
            0,
            80
        ],
        "C3_f": [
            0,
            80
        ],
        "tip": [
            0,
            4
        ],
        "C1_f": [
            -40,
            80
        ]
    },
    "safety": {
        "pattern": "long-short-long",
        "no_extrapolation": true,
        "sys_identity_strict": true,
        "ambiguity_policy": "error"
    },
    "space_rule": {
        "grid": "frame",
        "snap_tolerance": 0.02,
        "frame_constants": {
            "BOTTOM": -2.25,
            "TOP": 42.25,
            "LEFT": -2.25,
            "RIGHT": 82.25
        }
    },
    "mappings": null,
    "meta": {
        "version": "1.0",
        "role": "system_definition",
        "notes": [
            "2/3 system is a deterministic calculation-based system",
            "First cushion (C1) is derived from CO, C3, and discrete tip adjustment",
            "Tip unit is treated as a system-space scalar (5 units per tip)",
            "No candidate expansion or interpolation is performed",
            "All calculations are executed strictly in system-value space"
        ]
    }
}